# CoreHub API production bootstrap config.
# Default local bootstrap remains local JSON so developer and CI flows stay deterministic.
COREHUB_STATE_STORE=local-json
COREHUB_DATA_ROOT=.corehub-local
COREHUB_STATE_PATH=.corehub-local/write-side-state.json
COREHUB_STORAGE_ROOT=.corehub-local/storage
COREHUB_PUBLIC_BASE_URL=https://coreblow.com/corehub
COREHUB_AUDIT_RETENTION_DAYS=365
COREHUB_ADMIN_ACTORS=github:coreblow-admin,moderator:corehub
COREHUB_ANALYTICS_SALT=replace-with-operator-managed-analytics-salt
COREHUB_SIGNING_KEY_ID=local-dev
COREHUB_REQUIRE_SESSION_TOKEN_HASHES=1
# COREHUB_SIGNING_SECRET=replace-with-operator-managed-secret
# COREHUB_SIGNING_PREVIOUS_SECRETS=old-key-id:old-secret-value
# COREHUB_SESSION_TOKEN_SHA256=sha256-of-shared-browser-session-token
# COREHUB_ADMIN_TOKEN_SHA256=sha256-of-admin-browser-session-token
# COREHUB_PUBLISHER_TOKEN_SHA256=sha256-of-publisher-browser-session-token

# Enable this only when the runtime provides a D1 binding object named COREHUB_D1.
# Production-lite Worker deployments can run without R2 by storing artifact URL references.
# COREHUB_STATE_STORE=d1
# COREHUB_D1_STATE_KEY=write-side-state
# COREHUB_D1_STATE_TABLE=corehub_state
# COREHUB_OBJECT_STORE=external-url
# Set COREHUB_OBJECT_STORE=r2 and COREHUB_R2_BUCKET_NAME=corehub-artifacts only when managed uploads are enabled.
