# CoreHub audit incident production job configuration.
# Copy into the job environment, not into a committed secret file.

COREHUB_REGISTRY=https://coreblow.com/corehub
COREHUB_AUDIT_INCIDENT_REPORT=.corehub-audit/corehub-audit-incident.md
COREHUB_AUDIT_INCIDENT_FORMAT=markdown
COREHUB_AUDIT_INCIDENT_LIMIT=50

# Optional when the production audit API requires bearer auth.
# COREHUB_TOKEN=replace-with-secret-token
# COREHUB_USER=github:coreblow-admin
# COREHUB_PUBLISHER=coreblow

# Optional alert destination for fail_closed reports.
# COREHUB_AUDIT_ALERT_DESTINATION=slack
# COREHUB_AUDIT_ALERT_DESTINATION=teams
# COREHUB_AUDIT_ALERT_DESTINATION=email
# COREHUB_AUDIT_ALERT_DESTINATION=webhook
# COREHUB_AUDIT_ALERT_WEBHOOK=https://example.invalid/corehub-audit-alert
# COREHUB_AUDIT_RUNBOOK_URL=https://github.com/coreblow/corehub/blob/main/docs/audit-incident-response.md
# COREHUB_AUDIT_ALERT_RETRIES=2
# COREHUB_AUDIT_ALERT_RETRY_DELAY_MS=250
# COREHUB_AUDIT_ALERT_TIMEOUT_MS=5000
# COREHUB_AUDIT_ALERT_DEAD_LETTER_PATH=.corehub-audit/corehub-audit-alert-dead-letter.json
# COREHUB_AUDIT_ALERT_METRICS_PATH=.corehub-audit/corehub-audit-alert-delivery-metrics.jsonl

# Optional email adapter fields when destination=email.
# COREHUB_AUDIT_ALERT_EMAIL_TO=security@example.com
# COREHUB_AUDIT_ALERT_EMAIL_FROM=corehub@example.com
# COREHUB_AUDIT_ALERT_EMAIL_SUBJECT=CoreHub audit fail_closed
