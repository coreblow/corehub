{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coreblow.com/schemas/corehub.write-side.schema.json",
  "title": "CoreHub Write-Side Registry State",
  "description": "Planned write-side registry schema for CoreHub publisher accounts, package submissions, artifact uploads, moderation, ownership transfers, and install analytics.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAt",
    "authSessions",
    "publisherClaims",
    "publisherAccounts",
    "publisherMembers",
    "packageSubmissions",
    "packageVersions",
    "artifactUploads",
    "moderationReviews",
    "ownershipTransfers",
    "installEvents",
    "auditEvents",
    "auditRetentionCheckpoints"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "enum": ["corehub.write.v1"]
    },
    "generatedAt": {
      "$ref": "#/$defs/timestamp"
    },
    "authSessions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/authSession"
      }
    },
    "userAccounts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/userAccount"
      }
    },
    "publisherClaims": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/publisherClaim"
      }
    },
    "publisherAccounts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/publisherAccount"
      }
    },
    "publisherMembers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/publisherMember"
      }
    },
    "packageSubmissions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/packageSubmission"
      }
    },
    "packageVersions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/packageVersion"
      }
    },
    "packageSearchDigests": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/packageSearchDigest"
      }
    },
    "skillVersions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/skillVersion"
      }
    },
    "skillSearchDigests": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/skillSearchDigest"
      }
    },
    "communityStars": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/communityStar"
      }
    },
    "communityComments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/communityComment"
      }
    },
    "communityCommentReports": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/communityCommentReport"
      }
    },
    "artifactUploads": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifactUpload"
      }
    },
    "moderationReviews": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/moderationReview"
      }
    },
    "packageScanJobs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/packageScanJob"
      }
    },
    "ownershipTransfers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ownershipTransfer"
      }
    },
    "installEvents": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/installEvent"
      }
    },
    "auditEvents": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/auditEvent"
      }
    },
    "auditRetentionCheckpoints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/auditRetentionCheckpoint"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "handle": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "packageId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "semver": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "timestamp": {
      "type": "string",
      "minLength": 1
    },
    "url": {
      "type": "string",
      "pattern": "^https?://"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["user", "publisher", "moderator", "system"]
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "publisherHandle": {
          "$ref": "#/$defs/handle"
        }
      }
    },
    "authSession": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "actor", "status", "createdAt"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "actor": {
          "$ref": "#/$defs/actor"
        },
        "status": {
          "type": "string",
          "enum": ["active", "expired", "revoked"]
        },
        "defaultPublisherHandle": {
          "$ref": "#/$defs/handle"
        },
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "tokenHash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "tokenPreview": {
          "type": "string",
          "minLength": 1
        },
        "createdAt": {
          "$ref": "#/$defs/timestamp"
        },
        "expiresAt": {
          "$ref": "#/$defs/timestamp"
        }
      }
    },
    "userAccount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "provider", "providerAccountId", "login", "actorId", "status", "personalPublisherHandle", "createdAt", "updatedAt"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "provider": {
          "type": "string",
          "enum": ["github"]
        },
        "providerAccountId": {
          "type": "string",
          "minLength": 1
        },
        "login": {
          "$ref": "#/$defs/handle"
        },
        "actorId": {
          "type": "string",
          "minLength": 1
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["active", "suspended", "deleted"]
        },
        "avatarUrl": {
          "$ref": "#/$defs/url"
        },
        "profileUrl": {
          "$ref": "#/$defs/url"
        },
        "githubCreatedAt": {
          "$ref": "#/$defs/timestamp"
        },
        "personalPublisherHandle": {
          "$ref": "#/$defs/handle"
        },
        "createdAt": {
          "$ref": "#/$defs/timestamp"
        },
        "updatedAt": {
          "$ref": "#/$defs/timestamp"
        }
      }
    },
    "publisherClaim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "handle", "displayName", "kind", "status", "requestedBy", "requestedAt"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "handle": {
          "$ref": "#/$defs/handle"
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["user", "organization"]
        },
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "rejected", "cancelled"]
        },
        "source": {
          "$ref": "#/$defs/url"
        },
        "contact": {
          "$ref": "#/$defs/url"
        },
        "requestedBy": {
          "$ref": "#/$defs/actor"
        },
        "requestedAt": {
          "$ref": "#/$defs/timestamp"
        },
        "reviewId": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "publisherAccount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "handle", "displayName", "kind", "status", "createdAt"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "handle": {
          "$ref": "#/$defs/handle"
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["user", "organization"]
        },
        "status": {
          "type": "string",
          "enum": ["pending", "verified", "suspended", "blocked"]
        },
        "source": {
          "$ref": "#/$defs/url"
        },
        "contact": {
          "$ref": "#/$defs/url"
        },
        "createdAt": {
          "$ref": "#/$defs/timestamp"
        },
        "verifiedAt": {
          "$ref": "#/$defs/timestamp"
        },
        "linkedAccountId": {
          "$ref": "#/$defs/id"
        },
        "linkedUserId": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "publisherMember": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "publisherHandle", "userId", "role", "status", "createdAt"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "publisherHandle": {
          "$ref": "#/$defs/handle"
        },
        "userId": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "enum": ["owner", "admin", "maintainer", "reviewer"]
        },
        "status": {
          "type": "string",
          "enum": ["active", "invited", "removed"]
        },
        "createdAt": {
          "$ref": "#/$defs/timestamp"
        },
        "updatedAt": {
          "$ref": "#/$defs/timestamp"
        },
        "removedAt": {
          "$ref": "#/$defs/timestamp"
        }
      }
    },
    "packageSubmission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "packageId",
        "kind",
        "publisherHandle",
        "version",
        "status",
        "artifactUploadId",
        "submittedBy",
        "submittedAt"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "packageId": {
          "$ref": "#/$defs/packageId"
        },
        "kind": {
          "type": "string",
          "enum": ["skill", "plugin", "provider", "channel"]
        },
        "publisherHandle": {
          "$ref": "#/$defs/handle"
        },
        "version": {
          "$ref": "#/$defs/semver"
        },
        "status": {
          "type": "string",
          "enum": ["draft", "pending_review", "approved", "rejected", "cancelled"]
        },
        "artifactUploadId": {
          "$ref": "#/$defs/id"
        },
        "source": {
          "$ref": "#/$defs/url"
        },
        "changelog": {
          "type": "string",
          "minLength": 1
        },
        "submittedBy": {
          "$ref": "#/$defs/actor"
        },
        "submittedAt": {
          "$ref": "#/$defs/timestamp"
        },
        "reviewId": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "packageVersion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "packageId",
        "version",
        "publisherHandle",
        "status",
        "artifactUploadId",
        "createdAt"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "packageId": {
          "$ref": "#/$defs/packageId"
        },
        "version": {
          "$ref": "#/$defs/semver"
        },
        "tag": {
          "$ref": "#/$defs/id"
        },
        "publisherHandle": {
          "$ref": "#/$defs/handle"
        },
        "status": {
          "type": "string",
          "enum": ["pending_review", "available", "deprecated", "blocked", "rejected"]
        },
        "artifactUploadId": {
          "$ref": "#/$defs/id"
        },
        "submissionId": {
          "$ref": "#/$defs/id"
        },
        "createdAt": {
          "$ref": "#/$defs/timestamp"
        },
        "publishedAt": {
          "$ref": "#/$defs/timestamp"
        },
        "moderationStatus": {
          "type": "string",
          "enum": ["pending", "approved", "held", "blocked"]
        }
      }
    },
    "packageSearchDigest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "packageId",
        "name",
        "normalizedName",
        "displayName",
        "family",
        "channel",
        "isOfficial",
        "executesCode",
        "category",
        "latestVersion",
        "capabilityTags",
        "scanStatus",
        "moderationState",
        "downloadEnabled",
        "searchText",
        "searchTokens",
        "entry",
        "updatedAt"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "packageId": {
          "$ref": "#/$defs/packageId"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "normalizedName": {
          "type": "string",
          "minLength": 1
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "family": {
          "type": "string",
          "enum": ["skill", "code-plugin", "bundle-plugin"]
        },
        "channel": {
          "$ref": "#/$defs/id"
        },
        "isOfficial": {
          "type": "boolean"
        },
        "executesCode": {
          "type": "boolean"
        },
        "category": {
          "$ref": "#/$defs/id"
        },
        "publisherHandle": {
          "anyOf": [{ "$ref": "#/$defs/handle" }, { "type": "null" }]
        },
        "summary": {
          "type": "string"
        },
        "latestVersion": {
          "$ref": "#/$defs/semver"
        },
        "capabilityTags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "scanStatus": {
          "type": "string",
          "minLength": 1
        },
        "moderationState": {
          "type": "string",
          "minLength": 1
        },
        "downloadEnabled": {
          "type": "boolean"
        },
        "stats": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "installs": {
              "type": "integer",
              "minimum": 0
            },
            "downloads": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "searchText": {
          "type": "string",
          "minLength": 1
        },
        "searchTokens": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "entry": {
          "type": "object"
        },
        "updatedAt": {
          "$ref": "#/$defs/timestamp"
        }
      }
    },
    "skillVersion": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "slug", "version", "publisherHandle", "displayName", "summary", "status", "files", "createdAt"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "slug": { "$ref": "#/$defs/id" },
        "version": { "$ref": "#/$defs/semver" },
        "publisherHandle": { "$ref": "#/$defs/handle" },
        "displayName": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["available", "blocked", "deprecated"] },
        "moderationStatus": { "type": "string", "enum": ["approved", "held", "blocked"] },
        "files": {
          "type": "array",
          "items": { "$ref": "#/$defs/skillFile" }
        },
        "createdAt": { "$ref": "#/$defs/timestamp" },
        "publishedAt": { "$ref": "#/$defs/timestamp" },
        "softDeletedAt": { "$ref": "#/$defs/timestamp" }
      }
    },
    "skillFile": {
      "type": "object",
      "additionalProperties": true,
      "required": ["path", "mediaType", "size", "sha256", "content"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "mediaType": { "type": "string", "minLength": 1 },
        "size": { "type": "integer", "minimum": 0 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "content": { "type": "string", "minLength": 1 }
      }
    },
    "skillSearchDigest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "slug", "displayName", "status", "scanStatus", "searchText", "searchTokens", "entry", "updatedAt"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "slug": { "$ref": "#/$defs/id" },
        "displayName": { "type": "string", "minLength": 1 },
        "publisherHandle": {
          "anyOf": [{ "$ref": "#/$defs/handle" }, { "type": "null" }]
        },
        "summary": { "type": "string" },
        "latestVersion": {
          "anyOf": [{ "$ref": "#/$defs/semver" }, { "type": "null" }]
        },
        "status": { "type": "string", "minLength": 1 },
        "scanStatus": { "type": "string", "minLength": 1 },
        "capabilityTags": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" }
        },
        "searchText": { "type": "string", "minLength": 1 },
        "searchTokens": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" }
        },
        "entry": { "type": "object" },
        "updatedAt": { "$ref": "#/$defs/timestamp" }
      }
    },
    "communityStar": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "targetType", "targetId", "actorId", "status", "starredAt"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "targetType": { "type": "string", "enum": ["package", "skill"] },
        "targetId": { "type": "string", "minLength": 1 },
        "actorId": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["active", "removed"] },
        "starredAt": { "$ref": "#/$defs/timestamp" },
        "unstarredAt": { "$ref": "#/$defs/timestamp" }
      }
    },
    "communityComment": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "targetType", "targetId", "actorId", "body", "status", "createdAt"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "targetType": { "type": "string", "enum": ["package", "skill"] },
        "targetId": { "type": "string", "minLength": 1 },
        "actorId": { "type": "string", "minLength": 1 },
        "body": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["visible", "hidden", "deleted"] },
        "reportCount": { "type": "integer", "minimum": 0 },
        "createdAt": { "$ref": "#/$defs/timestamp" },
        "deletedAt": { "$ref": "#/$defs/timestamp" }
      }
    },
    "communityCommentReport": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "commentId", "targetType", "targetId", "actorId", "reason", "status", "reportedAt"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "commentId": { "$ref": "#/$defs/id" },
        "targetType": { "type": "string", "enum": ["package", "skill"] },
        "targetId": { "type": "string", "minLength": 1 },
        "actorId": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["open", "reviewed", "closed"] },
        "reportedAt": { "$ref": "#/$defs/timestamp" }
      }
    },
    "artifactUpload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "packageId",
        "version",
        "publisherHandle",
        "status",
        "storage",
        "size",
        "sha256",
        "uploadedBy",
        "createdAt"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "packageId": {
          "$ref": "#/$defs/packageId"
        },
        "version": {
          "$ref": "#/$defs/semver"
        },
        "publisherHandle": {
          "$ref": "#/$defs/handle"
        },
        "status": {
          "type": "string",
          "enum": ["requested", "uploaded", "verified", "rejected", "deleted"]
        },
        "storage": {
          "$ref": "#/$defs/storage"
        },
        "upload": {
          "$ref": "#/$defs/uploadContract"
        },
        "mediaType": {
          "type": "string",
          "minLength": 1
        },
        "size": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "uploadedBy": {
          "$ref": "#/$defs/actor"
        },
        "createdAt": {
          "$ref": "#/$defs/timestamp"
        },
        "verifiedAt": {
          "$ref": "#/$defs/timestamp"
        },
        "files": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifactFile"
          }
        },
        "npm": {
          "$ref": "#/$defs/npmArtifact"
        }
      }
    },
    "artifactFile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "size", "sha256"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "size": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "npmArtifact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "integrity": {
          "type": "string",
          "minLength": 1
        },
        "shasum": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$"
        },
        "tarballName": {
          "type": "string",
          "minLength": 1
        },
        "unpackedSize": {
          "type": "integer",
          "minimum": 0
        },
        "fileCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "uploadContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "url", "expiresAt", "maxBytes", "headers", "signature"],
      "properties": {
        "method": {
          "type": "string",
          "enum": ["PUT", "POST"]
        },
        "url": {
          "$ref": "#/$defs/url"
        },
        "expiresAt": {
          "$ref": "#/$defs/timestamp"
        },
        "maxBytes": {
          "type": "integer",
          "minimum": 0
        },
        "headers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/uploadHeader"
          }
        },
        "signature": {
          "type": "string",
          "minLength": 16
        }
      }
    },
    "uploadHeader": {
      "type": "object",
