{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coreblow.com/schemas/corehub.catalog.schema.json",
  "title": "CoreHub Catalog",
  "description": "Public CoreHub directory catalog for CoreBlow skills, plugins, providers, and channels.",
  "type": "array",
  "minItems": 1,
  "items": {
    "$ref": "#/$defs/entry"
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "name", "summary", "source"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "kind": {
          "type": "string",
          "enum": ["skill", "plugin", "provider", "channel"]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "pattern": "^https://github\\.com/"
        },
        "homepage": {
          "type": "string",
          "pattern": "^https?://"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][0-9A-Za-z.-]+)?$"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          }
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "review": {
          "$ref": "#/$defs/review"
        },
        "coreblow": {
          "$ref": "#/$defs/coreblow"
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state"],
      "properties": {
        "state": {
          "type": "string",
          "enum": ["draft", "review", "verified", "deprecated"]
        },
        "checkedAt": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "coreblow": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "minCoreblowVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][0-9A-Za-z.-]+)?$"
        },
        "requiresEnv": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]*$"
          }
        },
        "requiresBins": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "platforms": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
