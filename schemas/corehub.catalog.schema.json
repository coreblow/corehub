{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coreblow.com/schemas/corehub.catalog.schema.json",
  "title": "CoreHub Catalog",
  "description": "Public CoreHub directory catalog for CoreBlow skills, plugins, providers, and channels.",
  "type": "array",
  "minItems": 1,
  "items": {
    "$ref": "#/$defs/entry"
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "name", "summary", "source"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^(?:[a-z0-9][a-z0-9-]*|@[a-z0-9][a-z0-9-]*\\/[a-z0-9][a-z0-9-]*)$"
        },
        "kind": {
          "type": "string",
          "enum": ["skill", "plugin", "provider", "channel"]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "pattern": "^https://github\\.com/"
        },
        "homepage": {
          "type": "string",
          "pattern": "^https?://"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][0-9A-Za-z.-]+)?$"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          }
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "publisher": {
          "$ref": "#/$defs/publisher"
        },
        "versions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/version"
          }
        },
        "review": {
          "$ref": "#/$defs/review"
        },
        "coreblow": {
          "$ref": "#/$defs/coreblow"
        }
      }
    },
    "version": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "publishedAt", "publisher", "status", "artifact"],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][0-9A-Za-z.-]+)?$"
        },
        "tag": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "publishedAt": {
          "type": "string",
          "minLength": 1
        },
        "publisher": {
          "$ref": "#/$defs/versionPublisher"
        },
        "status": {
          "type": "string",
          "enum": ["metadata-only", "available", "deprecated", "blocked"]
        },
        "artifact": {
          "$ref": "#/$defs/artifact"
        }
      }
    },
    "versionPublisher": {
      "type": "object",
      "additionalProperties": false,
      "required": ["handle"],
      "properties": {
        "handle": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "mediaType", "size", "sha256", "downloadEnabled", "provenance", "files"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "mediaType": {
          "type": "string",
          "minLength": 1
        },
        "size": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "downloadEnabled": {
          "type": "boolean"
        },
        "storage": {
          "$ref": "#/$defs/storage"
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        },
        "files": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifactFile"
          }
        }
      }
    },
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "key", "url"],
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["github-raw", "r2", "s3", "external-url"]
        },
        "key": {
          "type": "string",
          "minLength": 1
        },
        "region": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "pattern": "^https?://"
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "reviewState"],
      "properties": {
        "source": {
          "type": "string",
          "pattern": "^https://github\\.com/"
        },
        "reviewState": {
          "type": "string",
          "enum": ["draft", "review", "verified", "deprecated"]
        }
      }
    },
    "artifactFile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "size", "sha256"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "size": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "publisher": {
      "type": "object",
      "additionalProperties": false,
      "required": ["handle", "displayName", "url", "verified"],
      "properties": {
        "handle": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "pattern": "^https?://"
        },
        "verified": {
          "type": "boolean"
        },
        "contact": {
          "type": "string",
          "pattern": "^https?://"
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state"],
      "properties": {
        "state": {
          "type": "string",
          "enum": ["draft", "review", "verified", "deprecated"]
        },
        "checkedAt": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "coreblow": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "minCoreblowVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][0-9A-Za-z.-]+)?$"
        },
        "requiresEnv": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]*$"
          }
        },
        "requiresBins": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "platforms": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
